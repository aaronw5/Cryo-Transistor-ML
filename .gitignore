# --- Python / OS / build junk ---
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.venv/
.env
.DS_Store
.ipynb_checkpoints/
bsim4.out

# --- Locally generated presentation decks (not shipped) ---
slides/
*.pptx

# --- Raw + heavy processed data (regenerate with scripts/setup_data.py) ---
data/raw/
data/processed/pdk_synth/*.npz
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/processed/pdk_synth/.gitkeep

# --- Figures: commit all PNGs (the README embeds them); skip heavy PDFs ---
figs/*.pdf

# --- out/: keep only the human-readable result tables and the final exported
#     card. Everything else (per-device sim data .npz, model checkpoints .pt,
#     and intermediate/experimental runs) is regenerable via the documented
#     pipeline, so it stays out of the repo. ---
out/*
!out/.gitkeep
!out/tables/
out/tables/*
!out/tables/.gitkeep
!out/tables/*.md
!out/tables/*.json
!out/tables/*.csv
!out/pdk_ml_selected/
out/pdk_ml_selected/*
!out/pdk_ml_selected/cards/
out/pdk_ml_selected/cards/*
!out/pdk_ml_selected/cards/*.spice
!out/pdk_ml_selected/cards/manifest.json
